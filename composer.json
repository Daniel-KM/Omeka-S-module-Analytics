{
    "name": "daniel-km/omeka-s-module-analytics",
    "type": "omeka-s-module",
    "description": "Module for Omeka S: Analytics about viewed pages.",
    "keywords": [
        "Omeka S",
        "Omeka S module",
        "administration",
        "analytics"
    ],
    "license": "CECILL-2.1",
    "homepage": "https://gitlab.com/Daniel-KM/Omeka-S-module-Analytics",
    "authors": [
        {
            "name": "Daniel Berthereau",
            "email": "Daniel.packagist@Berthereau.net"
        }
    ],
    "support": {
        "issues": "https://gitlab.com/Daniel-KM/Omeka-S-module-Analytics/issues",
        "forum": "https://forum.omeka.org/"
    },
    "_require (not set until Omeka S merges PR #2412)": {
        "omeka/omeka-s": "^4.0",
        "daniel-km/omeka-s-module-common": "*"
    },
    "require": {
        "openspout/openspout": "^3.7"
    },
    "autoload": {
        "psr-4": {
